# Copy to .env and fill in. With no keys the broker runs in MOCK mode (scripted narration)
# so the whole app still works end-to-end for local dev/demos.
#
# Configure any/all providers — the app shows a model picker for whichever have a key.
# Only Gemini can do the live audio/video stream; OpenAI and Anthropic use frames + captions + TTS.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

GEMINI_MODEL=gemini-2.0-flash-live-001
PORT=8787
