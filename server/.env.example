# Copy to .env and fill in. With no keys the broker runs in MOCK mode (scripted narration)
# so the whole app still works end-to-end for local dev/demos.
#
# Configure any/all providers — the app shows a model picker for whichever have a key.
# Only Gemini can do the live audio/video stream; OpenAI and Anthropic use frames + captions + TTS.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

GEMINI_MODEL=gemini-2.0-flash-live-001
PORT=8787

# Optional: use Google Maps as the basemap instead of the free key-less MapLibre map.
# This is a BROWSER key (every visitor receives it), so in the Google Cloud console
# restrict it to your domain (HTTP referrers) + the Maps JavaScript API only, and make
# sure the project has billing and the Maps JavaScript API enabled.
GOOGLE_MAPS_KEY=
# Optional Map ID for cloud-based styling; leave empty for the default look.
GOOGLE_MAP_ID=
