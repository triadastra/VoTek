# Copy to .env.local (gitignored) and fill in. All VITE_ vars are baked into the client
# bundle at build time — anything here is PUBLIC, so only browser-safe keys belong in it.

# Map backend: 'maplibre' (default — free, no key needed) or 'google'.
VITE_MAP_BACKEND=maplibre

# Only needed for VITE_MAP_BACKEND=google. Create the key in the Google Cloud console with
# billing enabled + the Maps JavaScript API turned on, and RESTRICT it to your site's domain
# (Application restrictions → HTTP referrers) — browser keys are visible to anyone.
VITE_GOOGLE_MAPS_KEY=

# Optional: a Map ID from the console for cloud-based map styling.
VITE_GOOGLE_MAP_ID=
